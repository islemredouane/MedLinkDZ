# Server
PORT=5000

# Database (PostgreSQL)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/medlinkdz
# Or use individual vars if your driver expects them:
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=medlinkdz

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Uploads
UPLOAD_DIR=./uploads
